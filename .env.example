# ============================================
# ARISARA FRONTEND - ENVIRONMENT VARIABLES
# ============================================
# Copie para .env e ajuste. Todas as variáveis precisam do prefixo VITE_

# URL da API (em produção = URL do Gateway)
# Dev: Core direto ou Gateway local (Nyoka backend)
# Prod: https://api.nyoka.com (ou domínio do Gateway Nyoka)
VITE_BACKEND_URL=http://localhost:8000

# Alternativa usada em alguns módulos (api.ts, useWebSocket)
# Em prod use a mesma URL do Gateway
VITE_API_URL=http://localhost:8001

# Link para a landing (signup, login, etc.) da Arisara
VITE_LANDING_URL=https://arisara.com.br

# Porta do dev server (opcional)
VITE_DEV_PORT=5173

# Discovery API (se diferente do backend)
# VITE_DISCOVERY_API_URL=

# Cloudinary (se usar upload de imagens)
# VITE_CLOUDINARY_CLOUD_NAME=seu_cloud_name

# Mock login (acessa a plataforma sem backend - use apenas em dev)
VITE_MOCK_AUTH=true
